{
  "name": "vehicle-service",
  "version": "1.0.0",
  "description": "EDG Vehicle Management Microservice",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migration:run": "node_modules/.bin/sequelize.cmd db:migrate",
    "migration:undo": "node_modules/.bin/sequelize.cmd db:migrate:undo",
    "migration:undo:all": "node_modules/.bin/sequelize.cmd db:migrate:undo:all",
    "migration:status": "node_modules/.bin/sequelize.cmd db:migrate:status"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
